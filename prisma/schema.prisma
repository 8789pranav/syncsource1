  tenantId         String
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  courseName       String
  trainingType     String? // Online | Classroom | On-the-job | External
  startDate        DateTime?
  endDate          DateTime?
  status           String    @default("Assigned") // Assigned | In Progress | Completed | Pending | Cancelled
  score            Float?
  certificateUrl   String?
  trainerFeedback  String?
  employeeFeedback String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model EmployeePerformanceGoal {
  id            String    @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  kra           String? // Key Result Area
  kpi           String? // Key Performance Indicator
  targetValue   String?
  achievedValue String?
  progress      Float? // 0-100
  weightage     Float?
  cycle         String? // FY2026-Q1 | FY2026-H1 | FY2026
  status        String    @default("Draft") // Draft | Submitted | Manager reviewed | HR reviewed | Finalized
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EmployeePerformanceReview {
  id                   String    @id @default(cuid())
  tenantId             String
  employeeId           String
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle                String // FY2026 | FY2026-H1
  type                 String? // Self | Manager | HR | Final | 360
  reviewerName         String?
  rating               Float? // 1-5
  comments             String?
  promotionRecommended Boolean   @default(false)
  incrementRecommended Float?
  status               String    @default("Draft") // Draft | Submitted | Manager reviewed | HR reviewed | Finalized
  pipStatus            String? // None | Active | Completed | Cancelled
  pipNotes             String?
  reviewDate           DateTime?
  finalizedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model EmployeeExpense {
  id            String    @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category      String? // Travel | Food | Stay | Conveyance | Mobile | Internet | Other
  amount        Float
  currency      String    @default("INR")
  expenseDate   DateTime  @default(now())
  description   String?
  billUrl       String?
  project       String?
  client        String?
  status        String    @default("Draft") // Draft | Submitted | Approved | Rejected | Paid | Cancelled
  paymentStatus String? // Pending | Paid | Reimbursed
  approvedBy    String?
  approvedAt    DateTime?
  paidAt        DateTime?
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EmployeeHelpdeskTicket {
  id            String    @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  ticketCode    String
  subject       String
  category      String? // HR | IT | Payroll | Finance | Admin | Facilities | POSH | Whistleblower
  priority      String    @default("Medium") // Low | Medium | High | Urgent
  status        String    @default("Open") // Open | In Progress | Resolved | Closed | Reopened
  description   String?
  assignedTo    String?
  slaHours      Int?
  slaStatus     String? // Within SLA | Breaching | Breached
  resolution    String?
  resolvedAt    DateTime?
  feedback      String?
  rating        Int?
  attachmentUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, ticketCode])
}

model EmployeeLetter {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  letterType String // Offer | Appointment | Confirmation | Increment | Promotion | Transfer | Warning | Experience | Relieving | Termination | Internship | NDA
  letterCode String?
  issuedDate DateTime @default(now())
  subject    String?
  body       String?
  pdfUrl     String?
  status     String   @default("Generated") // Draft | Generated | Issued | E-signed | Cancelled
  issuedBy   String?
  approvedBy String?
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmployeeRequest {
  id          String    @id @default(cuid())
  tenantId    String
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requestType String // Leave | Attendance regularization | Profile update | Document update | Bank update | Expense claim | Asset request | Travel | WFH | Shift change | Resignation
  referenceId String? // id of related record (leave application id, etc.)
  title       String
  description String?
  payload     String? // JSON of request-specific fields
  status      String    @default("Pending") // Draft | Pending | Approved | Rejected | Cancelled | Withdrawn
  pendingWith String?
  submittedAt DateTime  @default(now())
  decidedAt   DateTime?
  decidedBy   String?
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// LEAVE MANAGEMENT (industry-grade: Types, Rules/Policies,
// Applicability, Entitlement, Accrual, Restrictions, Carry Forward,
// Encashment, LOP, Comp-Off, Workflow, Ledger, Balance, Calendar,
// Holiday, Weekly Off, Adjustments, Bulk, Audit)
// ============================================================

// --- LEAVE TYPE (master) --------------------------------------
model LeaveType {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String
  name         String
  description  String?
  color        String  @default("#10b981")
  icon         String? // lucide icon name
  displayOrder Int     @default(0)

  // Classification
  category         String  @default("Annual") // Annual | Sick | Casual | Statutory | Unpaid | CompOff | Special
  isPaid           Boolean @default(true)
  paidType         String  @default("Paid") // Paid | Unpaid | PartiallyPaid
  leaveUnit        String  @default("FullDay") // FullDay | HalfDay | Hourly | Mixed
  balanceRequired  Boolean @default(true)
  negativeAllowed  Boolean @default(false)
  payrollImpact    String  @default("Paid") // Paid | LOP | PartialDeduction | NoEffect
  attendanceImpact String  @default("Leave") // Leave | Absent | WeeklyOff | HolidayOverride

  // Eligibility
  genderApplicability     String  @default("All") // All | Male | Female | Other
  maritalApplicability    String  @default("All") // All | Married | Unmarried
  employmentApplicability String  @default("All") // All | Permanent | Contract | Intern | Probation | Consultant
  countryApplicability    String? // comma-separated country codes; null = all

  // Allowed modes
  fullDayAllowed    Boolean @default(true)
  halfDayAllowed    Boolean @default(false)
  hourlyAllowed     Boolean @default(false)
  quarterDayAllowed Boolean @default(false)

  // Accrual defaults (can be overridden per-rule)
  monthlyAccrual Float @default(0)
  yearlyAccrual  Float @default(0)
  openingBalance Float @default(0)

  // Carry forward / encashment defaults
  carryForward      Boolean @default(false)
  carryForwardLimit Float?
  encashment        Boolean @default(false)
  encashmentLimit   Float?

  // Document rules
  attachmentRequired      Boolean @default(false)
  attachmentThresholdDays Int     @default(0) // require attachment if leave > N days
  reasonRequired          Boolean @default(true)

  // Application window
  minDays          Int     @default(1)
  maxDays          Int?
  maxContinuous    Int?
  backdatedAllowed Boolean @default(true)
  backdatedLimit   Int     @default(0) // days
  futureAllowed    Boolean @default(true)
  futureLimit      Int     @default(0) // days
  advanceNotice    Int     @default(0) // days

  // Advanced toggles
  allowCancellation        Boolean @default(true)
  allowWithdrawal          Boolean @default(true)
  allowClubbing            Boolean @default(true)
  // Clubbing config: comma-separated leave type codes that THIS type can be clubbed with.
  // null/empty = can be clubbed with all allowed types.
  clubbingWith             String?
  // Sandwich rule config
  sandwichRule             Boolean @default(false)
  sandwichIncludeWeeklyOff Boolean @default(false) // count weekly offs between leave days
  sandwichIncludeHolidays  Boolean @default(false) // count holidays between leave days
  showInCalendar           Boolean @default(true)
  showInPayslip            Boolean @default(true)
  showBalanceToEmployee    Boolean @default(true)
  showPolicyToEmployee     Boolean @default(true)
  allowManagerApply        Boolean @default(false)
  allowHrApply             Boolean @default(true)

  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies         LeavePolicyItem[]
  applications     LeaveApplication[]
  balances         LeaveBalance[]
  ledgerEntries    LeaveLedger[]
  adjustments      LeaveAdjustment[]
  encashments      LeaveEncashmentRequest[]
  carryForwardLogs LeaveCarryForwardLog[]

  @@unique([tenantId, code])
}

// --- LEAVE SETTINGS (per-tenant default OR per-entity override) -------------
// entityId = "__default__" for tenant-wide defaults, or a real Entity.id for
// entity-specific overrides. Settings are stored as a JSON blob.
model LeaveSetting {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityId     String   @default("__default__") // "__default__" or real entity id
  settingsJson String   @default("{}") // JSON blob of all leave settings
  updatedAt    DateTime @updatedAt
  updatedBy    String?

  @@unique([tenantId, entityId])
}

// --- LEAVE RULE / POLICY (container of leave types + applicability) ---
model LeavePolicy {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  description String?

  // Calendar / year
  country            String    @default("India")
  leaveYearType      String    @default("CalendarYear") // CalendarYear | FinancialYear | Custom | JoiningDate
  calendarStartMonth Int       @default(1) // 1=Jan
  effectiveFrom      DateTime?
  effectiveTo        DateTime?
  version            Int       @default(1)
  isDefault          Boolean   @default(false)
  priority           Int       @default(0) // higher wins when multiple rules match
  status             String    @default("Active") // Active | Draft | Inactive

  // Settings snapshot (JSON): general toggles for this rule
  settingsJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  items           LeavePolicyItem[]
  applicabilities LeaveRuleApplicability[]

  @@unique([tenantId, code])
}

// --- LEAVE RULE ↔ LEAVE TYPE mapping (per-rule config) ---------
model LeavePolicyItem {
  id            String      @id @default(cuid())
  leavePolicyId String
  leavePolicy   LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)
  leaveTypeId   String
  leaveType     LeaveType   @relation(fields: [leaveTypeId], references: [id])

  displayName String? // override name in this rule
  isActive    Boolean @default(true)

  // Entitlement
  entitlementType  String  @default("Fixed") // Fixed | Accrual | Experience | Attendance | Grant | Manual | Unlimited | None
  totalEntitlement Float   @default(0)
  entitlementUnit  String  @default("Days") // Days | Hours
  creditTiming     String  @default("YearStart") // YearStart | Monthly | Joining | Custom
  prorateNewJoiner Boolean @default(true)
  roundingRule     String  @default("NoRounding") // NoRounding | Up | Down | NearestHalf

  // Accrual
  accrualFrequency    String  @default("Yearly") // Daily | Weekly | Monthly | Quarterly | HalfYearly | Yearly | PayrollCycle | Attendance
  accrualAmount       Float   @default(0)
  accrualDate         Int     @default(1) // day of month/period
  accrualStartFrom    String  @default("PolicyStart") // PolicyStart | JoiningDate
  maxAccrualLimit     Float?
  stopAccrualOnLop    Boolean @default(false)
  stopAccrualOnNotice Boolean @default(false)

  // Restrictions
  minLeavePerRequest  Float  @default(1)
  maxLeavePerRequest  Float?
  maxContinuous       Float?
  maxPerMonth         Float?
  maxPerYear          Float?
  minGapBetweenLeaves Int    @default(0)

  // Document
  attachmentRequired      Boolean @default(false)
  attachmentThresholdDays Int     @default(0)

  // Carry forward
  carryForward                 Boolean @default(false)
  maxCarryForward              Float?
  carryForwardExpiryMonths     Int     @default(0) // 0 = no expiry
  carryForwardApprovalRequired Boolean @default(false)

  // Encashment
  encashment                 Boolean @default(false)
  encashmentMinBalance       Float?
  encashmentMaxDays          Float?
  encashmentFormula          String? // e.g. "Basic/30*Days"
  encashmentPayrollComponent String?

  // Negative balance
  allowNegativeBalance Boolean @default(false)
  maxNegativeBalance   Float?

  // LOP
  isLop                  Boolean @default(false)
  autoConvertAbsentToLop Boolean @default(false)

  // Workflow override (JSON step config; null = use default leave workflow)
  workflowOverrideJson String?

  // Clubbing (JSON list of allowed/restricted leave type ids + rules)
  clubbingAllowed    Boolean @default(true)
  clubbingConfigJson String?

  // Sandwich
  sandwichRule       Boolean @default(false)
  includeHolidays    Boolean @default(false)
  includeWeeklyOffs  Boolean @default(false)
  sandwichConfigJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leavePolicyId, leaveTypeId])
}

// --- LEAVE RULE APPLICABILITY (who the rule applies to) --------
model LeaveRuleApplicability {
  id                 String      @id @default(cuid())
  tenantId           String
  leavePolicyId      String
  leavePolicy        LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)
  applyTo            String      @default("AllEmployees") // AllEmployees | SelectedEntities | SelectedLocations | SelectedDepartments | SelectedGrades | SelectedEmployeeTypes | CustomGroup | SpecificEmployees
  entityIds          String? // comma-separated
  branchIds          String?
  locationIds        String?
  departmentIds      String?
  designationIds     String?
  gradeIds           String?
  employeeTypeIds    String? // comma-separated employment types
  employeeIds        String? // comma-separated specific employees
  excludeEmployeeIds String?
  gender             String      @default("All")
  createdAt          DateTime    @default(now())
}

// --- LEAVE APPLICATION -----------------------------------------
model LeaveApplication {
  id                String    @id @default(cuid())
  tenantId          String
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId       String
  leaveType         LeaveType @relation(fields: [leaveTypeId], references: [id])
  leavePolicyItemId String? // which rule item configured this leave

  fromDate    DateTime
  toDate      DateTime
  days        Float
  halfDay     Boolean  @default(false)
  halfDayType String? // FirstHalf | SecondHalf (when halfDay)
  hours       Float? // when hourly

  reason         String?
  attachmentUrl  String?
  attachmentName String?

  // Extra employee-supplied info
  emergencyContact    String?
  backupPersonId      String?
  handoverNotes       String?
  notifyTeamMemberIds String? // comma-separated employee ids
  addressDuringLeave  String?
  contactDuringLeave  String?

  // Dynamic / leave-type-specific fields stored as JSON
  extraFieldsJson String?

  status             String    @default("Pending") // Draft | Pending | PendingHR | Approved | Rejected | Cancelled | Withdrawn | PartiallyApproved | AutoApproved | Expired
  appliedAt          DateTime  @default(now())
  decisionAt         DateTime?
  decisionBy         String?
  decisionComment    String?
  currentApproverId  String?
  workflowInstanceId String?

  // Partial approval
  approvedFromDate DateTime?
  approvedToDate   DateTime?
  approvedDays     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  days_log      LeaveApplicationDay[]
  approvals     LeaveApproval[]
  ledgerEntries LeaveLedger[]
}

// Per-day breakdown (half-day, sandwich, holiday inclusion, etc.)
model LeaveApplicationDay {
  id            String           @id @default(cuid())
  applicationId String
  application   LeaveApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  date          DateTime
  dayType       String           @default("FullDay") // FullDay | FirstHalf | SecondHalf | Hourly
  hours         Float?
  isHoliday     Boolean          @default(false)
  isWeeklyOff   Boolean          @default(false)
  counted       Boolean          @default(true) // false if excluded by sandwich/holiday rule
}

// Approval chain records
model LeaveApproval {
  id            String           @id @default(cuid())
  applicationId String
  application   LeaveApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  stepOrder     Int
  approverType  String // ReportingManager | DepartmentHead | HRManager | SpecificEmployee | Role
  approverId    String?
  approverName  String?
  action        String // Pending | Approve | Reject | SendBack | Delegate | Escalate
  comment       String?
  actedAt       DateTime?
  createdAt     DateTime         @default(now())
}

// --- LEAVE BALANCE (computed/materialized) ---------------------
model LeaveBalance {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId  String
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])
  year         Int
  opening      Float     @default(0)
  accrued      Float     @default(0)
  granted      Float     @default(0) // manual grants
  adjusted     Float     @default(0) // net manual adjustments (+/-)
  carryForward Float     @default(0)
  used         Float     @default(0)
  pending      Float     @default(0)
  encashed     Float     @default(0)
  lapsed       Float     @default(0)
  expired      Float     @default(0)

  @@unique([employeeId, leaveTypeId, year])
}

// --- LEAVE LEDGER (immutable transaction log) ------------------
model LeaveLedger {
  id              String    @id @default(cuid())
  tenantId        String
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId     String
  leaveType       LeaveType @relation(fields: [leaveTypeId], references: [id])
  transactionDate DateTime  @default(now())
  transactionType String // OpeningBalance | Accrual | ManualCredit | ManualDebit | LeaveApplied | LeaveApproved | LeaveCancelled | LeaveRejected | CarryForward | Encashment | Lapse | PayrollAdjustment | Migration
  credit          Float     @default(0)
  debit           Float     @default(0)
  balanceAfter    Float     @default(0)
  referenceType   String? // LeaveApplication | LeaveAdjustment | LeaveEncashment | LeaveCarryForward | Manual
  referenceId     String?
  remarks         String?
  createdBy       String?
  createdAt       DateTime  @default(now())

  application   LeaveApplication? @relation(fields: [applicationId], references: [id])
  applicationId String?
}

// --- LEAVE ADJUSTMENT (manual balance tweaks by HR) ------------
model LeaveAdjustment {
  id             String    @id @default(cuid())
  tenantId       String
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId    String
  leaveType      LeaveType @relation(fields: [leaveTypeId], references: [id])
  adjustmentType String // Credit | Debit
  amount         Float
  effectiveDate  DateTime  @default(now())
  reason         String?
  remarks        String?
  createdBy      String?
  createdAt      DateTime  @default(now())
}

// --- COMP-OFF CREDIT -------------------------------------------
model CompOffCredit {
  id                       String    @id @default(cuid())
  tenantId                 String
  employeeId               String
  employee                 Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  source                   String // WeeklyOffWork | HolidayWork | Overtime | OnCall | Manual
  sourceDate               DateTime
  earnedDate               DateTime  @default(now())
  hours                    Float     @default(0)
  days                     Float     @default(1)
  expiryDate               DateTime?
  status                   String    @default("Available") // Available | Used | Expired | Cancelled
  usedAgainstApplicationId String?
  approvedBy               String?
  remarks                  String?
  createdAt                DateTime  @default(now())
}

// --- LEAVE ENCASHMENT REQUEST ----------------------------------
model LeaveEncashmentRequest {
  id               String    @id @default(cuid())
  tenantId         String
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId      String
  leaveType        LeaveType @relation(fields: [leaveTypeId], references: [id])
  days             Float
  amount           Float?
  formula          String?
  status           String    @default("Pending") // Pending | Approved | Rejected | Processed
  requestedAt      DateTime  @default(now())
  decisionAt       DateTime?
  decisionBy       String?
  decisionComment  String?
  payrollComponent String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// --- LEAVE CARRY FORWARD LOG (year-end processing) -------------
model LeaveCarryForwardLog {
  id             String    @id @default(cuid())
  tenantId       String
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId    String
  leaveType      LeaveType @relation(fields: [leaveTypeId], references: [id])
  fromYear       Int
  toYear         Int
  carriedForward Float
  lapsed         Float
  encashed       Float
  processedAt    DateTime  @default(now())
  processedBy    String?
}

// --- WEEKLY OFF CALENDAR ---------------------------------------
model WeeklyOffCalendar {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  code          String
  entityIds     String? // comma-separated; null = all
  locationIds   String?
  weekOffType   String    @default("Fixed") // Fixed | AlternateSaturday | Rotational | ShiftBased | Custom
  // comma-separated weekday numbers (0=Sun ... 6=Sat) for fixed off
  fixedDays     String    @default("0") // default Sunday
  // JSON config for rotational/alternate (e.g. {"weekNumbers":[2,4],"weekday":6})
  configJson    String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  status        String    @default("Active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, code])
}

// --- LEAVE AUDIT LOG -------------------------------------------
model LeaveAuditLog {
  id            String    @id @default(cuid())
  tenantId      String
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  module        String    @default("Leave")
  action        String // LeaveTypeCreated | LeaveRuleCreated | LeaveApplied | LeaveApproved | BalanceAdjusted | CarryForwardProcessed | EncashmentProcessed | etc.
  referenceType String?
  referenceId   String?
  oldValue      String?
  newValue      String?
  performedBy   String?
  performedAt   DateTime  @default(now())
  ipAddress     String?
  reason        String?
}

// ============================================================
// SHIFT & ROSTER
// ============================================================

model Shift {
  id                  String   @id @default(cuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code                String
  name                String
  startTime           String // "09:00"
  endTime             String // "18:00"
  breakStart          String?
  breakEnd            String?
  workingHours        Float    @default(8)
  graceMinutes        Int      @default(15)
  graceOutMinutes     Int      @default(15)
  halfDayHours        Float    @default(4)
  fullDayHours        Float    @default(8)
  isNightShift        Boolean  @default(false)
  isFlexible          Boolean  @default(false)
  isCrossDay          Boolean  @default(false)
  autoPunchOut        Boolean  @default(false)
  overtimeEligible    Boolean  @default(false)
  bufferBefore        Int      @default(0)
  bufferAfter         Int      @default(0)
  earlyClockInAllowed Boolean  @default(true)
  lateClockOutAllowed Boolean  @default(true)
  allowBreak          Boolean  @default(true)
  paidBreak           Boolean  @default(false)
  autoAssign          Boolean  @default(false)
  color               String   @default("#10b981")
  status              String   @default("Active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  assignments   ShiftAssignment[]
  rosterEntries RosterEntry[]
  attendances   Attendance[]

