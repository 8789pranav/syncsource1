// HRMS — Industry-grade HR Management System schema
// Multi-tenant foundation. Phase 1: single default tenant (TENANT_ID in lib/db.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// TENANT / ORGANIZATION FOUNDATION
// ============================================================

model Tenant {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  legalName     String?
  logoUrl       String?
  brandColor    String   @default("#10b981")
  country       String   @default("India")
  currency      String   @default("INR")
  timezone      String   @default("Asia/Kolkata")
  dateFormat    String   @default("DD/MM/YYYY")
  financialYear String   @default("Apr-Mar")
  status        String   @default("Active") // Active | Trial | Suspended | Expired
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entities      Entity[]
  branches      Branch[]
  departments   Department[]
  designations  Designation[]
  grades        Grade[]
  locations     Location[]
  employees     Employee[]
  leaveTypes    LeaveType[]
  leavePolicies LeavePolicy[]
  shifts        Shift[]
  rosters       Roster[]
  holidays      Holiday[]
  assets        Asset[]
  assetCategories AssetCategory[]
  formSchemas   FormSchema[]
  workflows     Workflow[]
  announcements Announcement[]
  auditLogs     AuditLog[]
  salaryStructures SalaryStructure[]
  payrollRuns   PayrollRun[]
}

// ============================================================
// ORGANIZATION STRUCTURE
// ============================================================

model Entity {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  legalName   String
  tradeName   String?
  pan         String?
  gstin       String?
  tan         String?
  pfNumber    String?
  esiNumber   String?
  address     String?
  city        String?
  state       String?
  country     String   @default("India")
  currency    String   @default("INR")
  payrollApplicable  Boolean @default(true)
  attendanceApplicable Boolean @default(true)
  leaveApplicable    Boolean @default(true)
  status      String   @default("Active")
  effectiveDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees   Employee[]
  branches    Branch[]
  departments Department[]

  @@unique([tenantId, code])
}

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityId    String?
  entity      Entity?  @relation(fields: [entityId], references: [id])
  code        String
  name        String
  address     String?
  city        String?
  state       String?
  country     String?
  lat         Float?
  lng         Float?
  branchHeadId String?
  workingDays String   @default("Mon,Tue,Wed,Thu,Fri")
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees   Employee[]

  @@unique([tenantId, code])
}

model Department {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityId      String?
  entity        Entity?  @relation(fields: [entityId], references: [id])
  parentId      String?
  code          String
  name          String
  departmentHeadId String?
  costCenterId  String?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employees     Employee[]
  children      Department[] @relation("DeptHierarchy")
  parent        Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])

  @@unique([tenantId, code])
}

model Designation {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String
  name          String
  gradeId       String?
  grade         Grade?   @relation(fields: [gradeId], references: [id])
  level         Int?
  departmentId  String?
  jobDescription String?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employees     Employee[]

  @@unique([tenantId, code])
}

model Grade {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String
  name            String
  hierarchyLevel  Int
  minSalary       Float?
  maxSalary       Float?
  leaveEligibility Float?
  approvalAuthority Boolean @default(false)
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employees       Employee[]
  designations    Designation[]

  @@unique([tenantId, code])
}

model Location {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String
  name          String
  address       String?
  city          String?
  state         String?
  country       String?
  geoFenceRadius Float?
  timezone      String?
  attendanceMode String  @default("Web")
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employees     Employee[]

  @@unique([tenantId, code])
}

// ============================================================
// EMPLOYEE MASTER
// ============================================================

model Employee {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeCode    String
  firstName       String
  middleName      String?
  lastName        String?
  displayName     String?
  gender          String?  // Male | Female | Other
  dateOfBirth     DateTime?
  maritalStatus   String?
  bloodGroup      String?
  nationality     String   @default("Indian")
  religion        String?
  category        String?  // General | OBC | SC | ST
  profilePhotoUrl String?
  personalEmail   String?
  officialEmail   String?
  mobileNumber    String?
  alternateNumber String?

  // Identity documents
  passportNumber  String?
  drivingLicense  String?
  voterId         String?
  physicallyDisabled Boolean @default(false)
  disabilityDetails String?

  // Employment
  dateOfJoining   DateTime?
  employmentType  String   @default("Full-time") // Full-time | Part-time | Contract | Intern | Consultant | Apprentice | Temporary
  workerType      String   @default("Permanent")
  jobType         String?  // On-roll | Off-roll
  probationStatus String?  // On Probation | Confirmed | Extended | Not Confirmed
  probationStartDate DateTime?
  probationEndDate DateTime?
  confirmationDate DateTime?
  noticePeriod    Int?     // days
  noticePeriodStartDate DateTime?
  lastWorkingDate DateTime?
  employeeStatus   String  @default("Active") // Active | On Notice | Resigned | Terminated | Absconded | Retired | Inactive | Alumni
  workMode        String   @default("Work from office") // Work from office | Work from home | Hybrid | Field work
  businessUnit    String?
  costCenter      String?

  entityId        String?
  entity          Entity?  @relation(fields: [entityId], references: [id])
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id])
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  designationId   String?
  designation     Designation? @relation(fields: [designationId], references: [id])
  gradeId         String?
  grade           Grade?   @relation(fields: [gradeId], references: [id])
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  reportingManagerId String?
  functionalManagerId String?
  hrManagerId     String?

  // Policy assignments
  leavePolicyId       String?
  attendancePolicyId  String?
  payrollPolicyId     String?
  shiftPolicyId       String?
  holidayCalendarId   String?

  // Bank
  bankName        String?
  accountHolderName String?
  accountNumber   String?
  accountType     String?  // Savings | Current | Salary
  ifscCode        String?
  branchName      String?
  upiId           String?

  // Statutory
  panNumber       String?
  aadhaarNumber   String?
  uanNumber       String?
  pfNumber        String?
  esiNumber       String?
  ptLocation      String?
  pfApplicable    Boolean  @default(true)
  esiApplicable   Boolean  @default(false)
  ptApplicable    Boolean  @default(true)
  lwfApplicability String?
  gratuityApplicability String?
  taxRegime       String?  // Old | New
  tdsDeclarationStatus String? // Pending | Submitted | Verified

  // Address
  currentAddress  String?
  currentAddressLine2 String?
  currentCity     String?
  currentState    String?
  currentCountry  String?
  currentPincode  String?
  currentLandmark String?
  permanentAddress String?
  permanentAddressLine2 String?
  permanentCity   String?
  permanentState  String?
  permanentCountry String?
  permanentPincode String?
  sameAsCurrent   Boolean  @default(false)

  // Emergency contact
  emergencyContactName    String?
  emergencyContactRelation String?
  emergencyContactPhone   String?
  emergencyContactAltPhone String?
  emergencyContactEmail   String?
  emergencyContactAddress String?
  communicationPreference String? // Email | SMS | WhatsApp

  // Dynamic / custom data
  customData      String?  // JSON string of custom fields

  // Compensation
  ctc             Float?
  basicSalary     Float?
  hra             Float?
  specialAllowance Float?
  conveyanceAllowance Float?
  medicalAllowance Float?
  bonusAmount     Float?
  pfEmployee      Float?
  pfEmployer      Float?
  esiAmount       Float?
  professionalTax Float?
  tdsAmount       Float?
  grossSalary     Float?
  netSalary       Float?

  // Exit
  resignationDate DateTime?
  resignationReason String?
  exitStatus      String?  // Not initiated | Resignation submitted | Manager approved | HR approved | Clearance pending | FnF pending | Exit completed

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  leaveApplications  LeaveApplication[]
  leaveBalances      LeaveBalance[]
  shiftAssignments   ShiftAssignment[]
  rosterEntries      RosterEntry[]
  attendance         Attendance[]
  assetAssignments   AssetAssignment[]
  assetRequests      AssetRequest[]
  profileUpdateRequests ProfileUpdateRequest[]

  // Employee profile sub-records (Phase 2 — Employee module expansion)
  familyMembers      EmployeeFamilyMember[]
  educationRecords   EmployeeEducation[]
  experienceRecords  EmployeeExperience[]
  bankHistory        EmployeeBankDetail[]
  statutoryDetails   EmployeeStatutoryDetail[]
  documents          EmployeeDocument[]
  compensationHistory EmployeeCompensationHistory[]
  notes              EmployeeNote[]
  timelineEvents     EmployeeTimelineEvent[]
  auditLogs          EmployeeAuditLog[]
  statusHistory      EmployeeStatusHistory[]
  transferHistory    EmployeeTransferHistory[]
  promotionHistory   EmployeePromotionHistory[]
  probationReviews   EmployeeProbation[]
  exitRecords        EmployeeExit[]
  loginAccess        EmployeeLoginAccess[]
  roleMappings       EmployeeRoleMapping[]
  customFieldValues  EmployeeCustomFieldValue[]
  formSubmissions    EmployeeFormSubmission[]
  skills             EmployeeSkill[]
  certifications     EmployeeCertification[]
  trainings          EmployeeTraining[]
  performanceGoals   EmployeePerformanceGoal[]
  performanceReviews EmployeePerformanceReview[]
  expenses           EmployeeExpense[]
  helpdeskTickets    EmployeeHelpdeskTicket[]
  letters            EmployeeLetter[]
  requests           EmployeeRequest[]
  salaryAssignments  SalaryAssignment[]
  payslips           Payslip[]

  @@unique([tenantId, employeeCode])
}

model ProfileUpdateRequest {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fieldChanges String  // JSON string
  status      String   @default("Pending") // Pending | Approved | Rejected
  reason      String?
  requestedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
}

// ============================================================
// EMPLOYEE PROFILE SUB-RECORDS (Phase 2 — Employee module)
// ============================================================

model EmployeeFamilyMember {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name          String
  relationship  String?  // Spouse | Son | Daughter | Father | Mother | Brother | Sister | Other
  gender        String?
  dateOfBirth   DateTime?
  mobileNumber  String?
  occupation    String?
  isDependent   Boolean  @default(false)
  isNominee     Boolean  @default(false)
  nomineePercentage Float?
  insuranceApplicable Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeEducation {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  qualification String?  // 10th | 12th | Diploma | UG | PG | PhD | Certification
  degree        String?
  specialization String?
  institute     String?
  university    String?
  yearOfPassing Int?
  percentage    Float?
  cgpa          Float?
  educationType String?  // Full-time | Part-time | Distance | Online
  isHighest     Boolean  @default(false)
  certificateUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeExperience {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyName   String
  designation   String?
  department    String?
  startDate     DateTime?
  endDate       DateTime?
  totalYears    Float?
  reasonForLeaving String?
  previousSalary Float?
  managerName   String?
  managerContact String?
  experienceLetterUrl String?
  relievingLetterUrl String?
  lastPayslipUrl String?
  verificationStatus String? // Pending | Verified | Not Verified
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeBankDetail {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bankName      String
  accountHolderName String?
  accountNumber String
  ifscCode      String?
  branchName    String?
  accountType   String?  // Savings | Current | Salary
  upiId         String?
  chequeUrl     String?
  isActive      Boolean  @default(true)
  verified      Boolean  @default(false)
  effectiveDate DateTime @default(now())
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeStatutoryDetail {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  panNumber     String?
  aadhaarNumber String?
  uanNumber     String?
  pfNumber      String?
  esiNumber     String?
  ptLocation    String?
  lwfApplicability String?
  gratuityApplicability String?
  pfApplicable  Boolean  @default(true)
  esiApplicable Boolean  @default(false)
  ptApplicable  Boolean  @default(true)
  taxRegime     String?  // Old | New
  tdsDeclarationStatus String?
  nomineeDetails String? // JSON
  documentUrl   String?
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeDocument {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name          String
  category      String?  // Identity | Address | Education | Experience | Bank | Joining | Payroll | Company Letter | Exit | Other
  documentType  String?  // Aadhaar | PAN | Passport | Photo | Resume | Offer letter | etc.
  fileUrl       String?
  fileExt       String?  // pdf | jpg | png
  fileSize      Int?
  status        String   @default("Pending") // Pending | Uploaded | Approved | Rejected | Expired | Expiring soon
  expiryDate    DateTime?
  uploadedAt    DateTime @default(now())
  approvedAt    DateTime?
  approvedBy    String?
  remarks       String?
  visibleToEmployee Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeCompensationHistory {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  effectiveDate DateTime
  oldCtc        Float?
  newCtc        Float?
  oldBasic      Float?
  newBasic      Float?
  oldHra        Float?
  newHra        Float?
  incrementPercent Float?
  revisionReason String? // Annual appraisal | Promotion | Off-cycle | Joining
  promotionMapping String?
  approvedBy    String?
  status        String   @default("Approved") // Draft | Approved | Rejected
  letterUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeNote {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category      String   @default("General") // General | Performance | Disciplinary | Medical | HR discussion | Manager feedback | Exit discussion
  body          String
  isPrivate     Boolean  @default(false)
  visibleToManager Boolean @default(false)
  attachmentUrl String?
  createdBy     String?  // user name
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeTimelineEvent {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  eventType     String   // Created | Joined | Profile updated | Document uploaded | Leave approved | Attendance regularized | Salary revised | Promoted | Transferred | Manager changed | Probation confirmed | Asset assigned | Resignation submitted | Exit completed | Status changed
  title         String
  description   String?
  eventDate     DateTime @default(now())
  actorId       String?
  actorName     String?
  metadata      String?  // JSON
  createdAt     DateTime @default(now())
}

model EmployeeAuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  module        String?  // Personal | Job | Bank | Statutory | Document | etc.
  field         String?
  oldValue      String?
  newValue      String?
  action        String?  // Create | Update | Delete
  changedBy     String?
  reason        String?
  ipAddress     String?
  userAgent     String?
  approvalRef   String?
  createdAt     DateTime @default(now())
}

model EmployeeStatusHistory {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  oldStatus     String?
  newStatus     String
  effectiveDate DateTime @default(now())
  reason        String?
  changedBy     String?
  createdAt     DateTime @default(now())
}

model EmployeeTransferHistory {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  oldDepartment String?
  newDepartment String?
  oldLocation   String?
  newLocation   String?
  oldManager    String?
  newManager    String?
  oldEntity     String?
  newEntity     String?
  effectiveDate DateTime
  reason        String?
  status        String   @default("Approved") // Pending | Approved | Rejected
  approvedBy    String?
  createdAt     DateTime @default(now())
}

model EmployeePromotionHistory {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  oldDesignation String?
  newDesignation String?
  oldGrade      String?
  newGrade      String?
  oldCtc        Float?
  newCtc        Float?
  effectiveDate DateTime
  reason        String?
  status        String   @default("Approved") // Pending | Approved | Rejected
  approvedBy    String?
  letterUrl     String?
  createdAt     DateTime @default(now())
}

model EmployeeProbation {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  reviewDueDate DateTime?
  status        String   @default("On Probation") // On Probation | Review pending | Extended | Confirmed | Not Confirmed
  managerFeedback String?
  hrFeedback    String?
  extendedEndDate DateTime?
  confirmedDate DateTime?
  confirmedBy   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeExit {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  resignationDate DateTime
  lastWorkingDate DateTime?
  reason        String?
  status        String   @default("Resignation submitted") // Resignation submitted | Manager approved | HR approved | Clearance pending | FnF pending | Exit completed | Rejected
  noticePeriodDays Int?
  noticeRecoveryDays Int?
  noticeRecoveryAmount Float?
  exitInterviewNotes String?
  clearanceHR   Boolean  @default(false)
  clearanceIT   Boolean  @default(false)
  clearanceAdmin Boolean @default(false)
  clearanceFinance Boolean @default(false)
  clearanceManager Boolean @default(false)
  clearancePayroll Boolean @default(false)
  finalSettlement Float?
  relievingLetterUrl String?
  experienceLetterUrl String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeLoginAccess {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  username      String?
  email         String?
  status        String   @default("Active") // Active | Inactive | Blocked | Locked
  role          String?  // Employee | Manager | HR admin | Payroll admin | Finance admin | IT admin | Auditor | Sub-admin
  twoFactorEnabled Boolean @default(false)
  forcePasswordChange Boolean @default(true)
  passwordResetAt DateTime?
  lastLoginAt   DateTime?
  lastLoginIp   String?
  activeSessions Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeRoleMapping {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role          String   // Employee | Manager | HR admin | Payroll admin | Finance admin | IT admin | Auditor | Sub-admin
  scopeType     String?  // Global | Entity | Department | Location
  scopeRef      String?
  modulePermissions String? // JSON
  fieldPermissions  String? // JSON
  reportPermissions String? // JSON
  assignedAt    DateTime @default(now())
  assignedBy    String?
  isActive      Boolean  @default(true)
}

model EmployeeCustomFieldValue {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fieldKey      String
  fieldLabel    String?
  fieldType     String?  // text | number | date | select | multiselect | checkbox
  value         String?
  category      String?  // General | Project | Accommodation | Uniform | Other
  isMandatory   Boolean  @default(false)
  approvalRequired Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeId, fieldKey])
}

model EmployeeFormSubmission {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  formCode      String   // joining | policy_declaration | asset_declaration | medical | nominee | travel | wfh | custom
  formName      String?
  version       Int      @default(1)
  data          String?  // JSON of submitted values
  status        String   @default("Draft") // Draft | Submitted | Approved | Rejected
  submittedAt   DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  remarks       String?
  pdfUrl        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeSkill {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name          String
  category      String?  // Technical | Soft | Domain | Tool | Language
  proficiency   String?  // Beginner | Intermediate | Advanced | Expert
  yearsOfExperience Float?
  verifiedByManager Boolean @default(false)
  lastUsedDate  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeCertification {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name          String
  issuingAuthority String?
  issueDate     DateTime?
  expiryDate    DateTime?
  certificateId String?
  certificateUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeTraining {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  courseName    String
  trainingType  String?  // Online | Classroom | On-the-job | External
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("Assigned") // Assigned | In Progress | Completed | Pending | Cancelled
  score         Float?
  certificateUrl String?
  trainerFeedback String?
  employeeFeedback String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeePerformanceGoal {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  kra           String?  // Key Result Area
  kpi           String?  // Key Performance Indicator
  targetValue   String?
  achievedValue String?
  progress      Float?   // 0-100
  weightage     Float?
  cycle         String?  // FY2026-Q1 | FY2026-H1 | FY2026
  status        String   @default("Draft") // Draft | Submitted | Manager reviewed | HR reviewed | Finalized
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeePerformanceReview {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle         String   // FY2026 | FY2026-H1
  type          String?  // Self | Manager | HR | Final | 360
  reviewerName  String?
  rating        Float?   // 1-5
  comments      String?
  promotionRecommended Boolean @default(false)
  incrementRecommended Float?
  status        String   @default("Draft") // Draft | Submitted | Manager reviewed | HR reviewed | Finalized
  pipStatus     String?  // None | Active | Completed | Cancelled
  pipNotes      String?
  reviewDate    DateTime?
  finalizedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeExpense {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category      String?  // Travel | Food | Stay | Conveyance | Mobile | Internet | Other
  amount        Float
  currency      String   @default("INR")
  expenseDate   DateTime @default(now())
  description   String?
  billUrl       String?
  project       String?
  client        String?
  status        String   @default("Draft") // Draft | Submitted | Approved | Rejected | Paid | Cancelled
  paymentStatus String?  // Pending | Paid | Reimbursed
  approvedBy    String?
  approvedAt    DateTime?
  paidAt        DateTime?
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeHelpdeskTicket {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  ticketCode    String
  subject       String
  category      String?  // HR | IT | Payroll | Finance | Admin | Facilities | POSH | Whistleblower
  priority      String   @default("Medium") // Low | Medium | High | Urgent
  status        String   @default("Open") // Open | In Progress | Resolved | Closed | Reopened
  description   String?
  assignedTo    String?
  slaHours      Int?
  slaStatus     String?  // Within SLA | Breaching | Breached
  resolution    String?
  resolvedAt    DateTime?
  feedback      String?
  rating        Int?
  attachmentUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, ticketCode])
}

model EmployeeLetter {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  letterType    String   // Offer | Appointment | Confirmation | Increment | Promotion | Transfer | Warning | Experience | Relieving | Termination | Internship | NDA
  letterCode    String?
  issuedDate    DateTime @default(now())
  subject       String?
  body          String?
  pdfUrl        String?
  status        String   @default("Generated") // Draft | Generated | Issued | E-signed | Cancelled
  issuedBy      String?
  approvedBy    String?
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeeRequest {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requestType   String   // Leave | Attendance regularization | Profile update | Document update | Bank update | Expense claim | Asset request | Travel | WFH | Shift change | Resignation
  referenceId   String?  // id of related record (leave application id, etc.)
  title         String
  description   String?
  payload       String?  // JSON of request-specific fields
  status        String   @default("Pending") // Draft | Pending | Approved | Rejected | Cancelled | Withdrawn
  pendingWith   String?
  submittedAt   DateTime @default(now())
  decidedAt     DateTime?
  decidedBy     String?
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// LEAVE MANAGEMENT
// ============================================================

model LeaveType {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code            String
  name            String
  color           String   @default("#10b981")
  isPaid          Boolean  @default(true)
  fullDayAllowed  Boolean  @default(true)
  halfDayAllowed  Boolean  @default(false)
  hourlyAllowed   Boolean  @default(false)
  monthlyAccrual  Float    @default(0)
  yearlyAccrual   Float    @default(0)
  openingBalance  Float    @default(0)
  carryForward    Boolean  @default(false)
  carryForwardLimit Float?
  encashment      Boolean  @default(false)
  negativeAllowed Boolean  @default(false)
  attachmentRequired Boolean @default(false)
  reasonRequired  Boolean  @default(true)
  genderApplicability String? // All | Male | Female
  minDays         Int      @default(1)
  maxDays         Int?
  backdatedAllowed Boolean @default(true)
  futureAllowed   Boolean  @default(true)
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  policies        LeavePolicyItem[]
  applications    LeaveApplication[]
  balances        LeaveBalance[]

  @@unique([tenantId, code])
}

model LeavePolicy {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  description String?
  effectiveDate DateTime?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       LeavePolicyItem[]
}

model LeavePolicyItem {
  id          String   @id @default(cuid())
  leavePolicyId String
  leavePolicy LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  allocation  Float    @default(0)
}

model LeaveApplication {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  fromDate    DateTime
  toDate      DateTime
  days        Float
  halfDay     Boolean  @default(false)
  reason      String?
  attachmentUrl String?
  status      String   @default("Pending") // Pending | Approved | Rejected | Cancelled | Withdrawn
  appliedAt   DateTime @default(now())
  decisionAt  DateTime?
  decisionBy  String?
  decisionComment String?
  workflowInstanceId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeaveBalance {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  year        Int
  opening     Float    @default(0)
  accrued     Float    @default(0)
  used        Float    @default(0)
  pending     Float    @default(0)
  lapsed      Float    @default(0)

  @@unique([employeeId, leaveTypeId, year])
}

// ============================================================
// SHIFT & ROSTER
// ============================================================

model Shift {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String
  name          String
  startTime     String   // "09:00"
  endTime       String   // "18:00"
  breakStart    String?
  breakEnd      String?
  workingHours  Float    @default(8)
  graceMinutes Int      @default(15)
  halfDayHours  Float    @default(4)
  fullDayHours  Float    @default(8)
  isNightShift  Boolean  @default(false)
  isFlexible    Boolean  @default(false)
  autoPunchOut  Boolean  @default(false)
  overtimeEligible Boolean @default(false)
  color         String   @default("#10b981")
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignments   ShiftAssignment[]
  rosterEntries RosterEntry[]

  @@unique([tenantId, code])
}

model ShiftAssignment {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId     String
  shift       Shift    @relation(fields: [shiftId], references: [id])
  effectiveDate DateTime
  endDate     DateTime?
  isRecurring Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Roster {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  startDate   DateTime
  endDate     DateTime
  cycle       String   @default("Weekly") // Weekly | Monthly
  status      String   @default("Draft") // Draft | Published | Locked
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     RosterEntry[]

  @@unique([tenantId, code])
}

model RosterEntry {
  id          String   @id @default(cuid())
  rosterId    String
  roster      Roster   @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId     String?
  shift       Shift?   @relation(fields: [shiftId], references: [id])
  date        DateTime
  isWeeklyOff Boolean  @default(false)
  isHoliday   Boolean  @default(false)
  notes       String?
}

// ============================================================
// HOLIDAY & ATTENDANCE
// ============================================================

model Holiday {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  date        DateTime
  type        String   @default("National") // National | Regional | Optional | Restricted
  description String?
  country     String   @default("India")
  state       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  clockIn     DateTime?
  clockOut    DateTime?
  status      String   @default("Present") // Present | Absent | Half Day | Late | Weekly Off | Holiday | Leave | WFH | OD
  workHours   Float    @default(0)
  overtimeHours Float  @default(0)
  isLate      Boolean  @default(false)
  isEarlyGoing Boolean @default(false)
  remarks     String?
  source      String   @default("Web") // Web | Mobile | Biometric | Manual
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, date])
}

// ============================================================
// ASSET MANAGEMENT
// ============================================================

model AssetCategory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  icon        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets      Asset[]
  assetRequests AssetRequest[]

  @@unique([tenantId, code])
}

model Asset {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetCode   String
  name        String
  categoryId  String?
  category    AssetCategory? @relation(fields: [categoryId], references: [id])
  serialNumber String?
  assetTag    String?
  purchaseDate DateTime?
  purchaseValue Float?
  condition   String   @default("Good") // Good | Fair | Damaged | Lost
  status      String   @default("In Stock") // In Stock | Assigned | Returned | Damaged | Lost | Repair | Retired | Disposed
  assignedToId String?
  assignedDate DateTime?
  returnDate  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments AssetAssignment[]

  @@unique([tenantId, assetCode])
}

model AssetAssignment {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedDate DateTime
  returnDate  DateTime?
  condition   String   @default("Good")
  acknowledged Boolean @default(false)
  notes       String?
}

model AssetRequest {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    AssetCategory? @relation(fields: [categoryId], references: [id])
  requestType String   @default("New") // New | Replacement | Repair
  reason      String?
  status      String   @default("Pending") // Pending | Approved | Rejected | Fulfilled
  priority    String   @default("Medium")
  workflowInstanceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// DYNAMIC FORM ENGINE
// ============================================================

model FormSchema {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  module      String   // employee | entity | leaveType | shift | roster | asset | leaveApplication | assetRequest | custom
  description String?
  sections    String   // JSON: array of {title, fields: [...]}
  status      String   @default("Published") // Draft | Published
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
}

// ============================================================
// WORKFLOW ENGINE
// ============================================================

model Workflow {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  module      String   // leave | asset | attendance | employee | expense | onboarding
  event       String   // create | update | apply | request
  description String?
  approvalType String  @default("Sequential") // Sequential | Parallel | Auto
  conditions  String?  // JSON
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       WorkflowStep[]
  instances   WorkflowInstance[]

  @@unique([tenantId, code])
}

model WorkflowStep {
  id          String   @id @default(cuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  level       Int
  approverType String  // ReportingManager | DepartmentHead | HRManager | SpecificEmployee | Role
  approverId  String?  // employee id when SpecificEmployee
  approverRole String?
  slaHours    Int?
  name        String?

  instances   WorkflowAction[]
}

model WorkflowInstance {
  id          String   @id @default(cuid())
  tenantId    String
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id])
  module      String
  recordId    String   // the entity being approved
  initiatorId String?
  status      String   @default("Pending") // Pending | Approved | Rejected | Cancelled
  currentLevel Int     @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  actions     WorkflowAction[]
}

model WorkflowAction {
  id              String   @id @default(cuid())
  instanceId      String
  instance        WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepId          String
  step            WorkflowStep @relation(fields: [stepId], references: [id])
  action          String   // Approve | Reject | Escalate
  actorId         String?
  comment         String?
  actedAt         DateTime @default(now())
}

// ============================================================
// ANNOUNCEMENTS & AUDIT
// ============================================================

model Announcement {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  body        String?
  audience    String   @default("All") // All | Entity | Department | Location
  audienceRef String?
  publishDate DateTime @default(now())
  expiryDate  DateTime?
  priority    String   @default("Normal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module      String
  action      String   // Create | Update | Delete | Approve | Reject
  recordId    String?
  userId      String?
  userName    String?
  details     String?  // JSON
  ip          String?
  createdAt   DateTime @default(now())
}

// ============================================================
// PAYROLL MANAGEMENT (Phase 3)
// ============================================================

model SalaryStructure {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String
  name          String
  description   String?
  // Default component percentages (of CTC)
  basicPercent  Float    @default(50)
  hraPercent    Float    @default(20)
  specialAllowancePercent Float @default(20)
  conveyanceAllowance Float @default(1600)
  medicalAllowance Float  @default(1250)
  bonusAmount   Float    @default(0)
  // Employer contributions
  pfEmployerPercent Float @default(12)
  esiEmployerPercent Float @default(3.25)
  // Employee deductions
  pfEmployeePercent Float @default(12)
  esiEmployeePercent Float @default(0.75)
  professionalTax Float  @default(200)
  tdsPercent     Float   @default(0)
  status        String   @default("Active") // Active | Inactive
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignments   SalaryAssignment[]

  @@unique([tenantId, code])
}

model SalaryAssignment {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  salaryStructureId String
  salaryStructure SalaryStructure @relation(fields: [salaryStructureId], references: [id])
  ctc           Float
  basic         Float
  hra           Float
  specialAllowance Float
  conveyanceAllowance Float
  medicalAllowance Float
  bonusAmount   Float
  pfEmployee    Float
  pfEmployer    Float
  esiEmployee   Float
  esiEmployer   Float
  professionalTax Float
  tdsAmount     Float
  grossSalary   Float
  netSalary     Float
  effectiveDate DateTime
  endDate       DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PayrollRun {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String   // PR-2026-06
  name          String   // "June 2026 Payroll"
  payPeriod     String   // "2026-06"
  payPeriodStart DateTime
  payPeriodEnd  DateTime
  payDate       DateTime
  status        String   @default("Draft") // Draft | Processing | Completed | Approved | Paid | Cancelled
  processedAt   DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  paidAt        DateTime?
  totalGross    Float    @default(0)
  totalNet      Float    @default(0)
  totalDeductions Float  @default(0)
  totalEmployerContribution Float @default(0)
  employeeCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payslips      Payslip[]

  @@unique([tenantId, code])
}

model Payslip {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRunId  String
  payrollRun    PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  payPeriod     String
  payPeriodStart DateTime
  payPeriodEnd  DateTime
  payDate       DateTime
  // Earnings
  basic         Float
  hra           Float
  specialAllowance Float
  conveyanceAllowance Float
  medicalAllowance Float
  bonusAmount   Float
  grossEarnings Float
  // Deductions
  pfEmployee    Float
  esiEmployee   Float
  professionalTax Float
  tdsAmount     Float
  totalDeductions Float
  // Net
  netSalary     Float
  // Employer contributions (cost to company)
  pfEmployer    Float
  esiEmployer   Float
  totalEmployerContribution Float
  ctc           Float
  // Working days
  workingDays   Int      @default(30)
  daysPaid      Int      @default(30)
  lopDays       Int      @default(0) // Loss of pay
  status        String   @default("Generated") // Generated | Approved | Paid | Cancelled
  generatedAt   DateTime @default(now())
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([payrollRunId, employeeId])
}
